# Application (dev default; review NODE_ENV, DOCS_ENABLED, and OPENAPI_SERVER_URL per environment)
NODE_ENV=development
PORT=3000
HTTP_PORT=8080
API_PREFIX=/api/v1
APP_NAME=NestJS Monolith Template
API_VERSION=1
SHUTDOWN_TIMEOUT=10000
DOCS_ENABLED=true
OPENAPI_SERVER_URL=http://localhost:3000

# Database (required change in production; never reuse local credentials)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_monolith?schema=public
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nest_monolith
DATABASE_POOL_MAX=10
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# Redis (required change in production when Redis is not local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Logging (production normally uses info + json)
LOG_LEVEL=debug
LOG_OUTPUT=console

# CORS (required change in staging/production; never use wildcard origins)
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Rate limiting (review per environment)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Metrics (disable only when another telemetry path owns metrics)
METRICS_ENABLED=true

# pgAdmin (local docker only; not used by production compose)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
