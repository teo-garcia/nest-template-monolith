NODE_ENV=test
PORT=3001
API_PREFIX=/api
APP_NAME=NestJS Monolith Template
API_VERSION=1
DOCS_ENABLED=true
OPENAPI_SERVER_URL=http://localhost:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_monolith_test?schema=public
DATABASE_POOL_MAX=10
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600
LOG_LEVEL=warn
LOG_OUTPUT=console
CORS_ENABLED=false
CORS_ORIGIN=
THROTTLE_TTL=60
THROTTLE_LIMIT=1000
METRICS_ENABLED=true
